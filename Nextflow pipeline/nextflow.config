// ============================================================
// Klebsiella pneumoniae Analysis Pipeline - Configuration
// ============================================================

params {
    // Input/Output
    fasta_dir   = "${projectDir}/../Fasta files"
    reference   = "${projectDir}/../Fasta files/kp_ref_uncompressed.fasta"
    outdir      = "${projectDir}/results"

    // Prokka
    prokka_genus   = "Klebsiella"
    prokka_species = "pneumoniae"
    prokka_cpus    = 10

    // Snippy
    snippy_cpus    = 10
    snippy_mincov  = 10

    // IQ-TREE
    iqtree_model   = "GTR+G"
    iqtree_bootstrap = 1000

    // AMRFinder
    amrfinder_organism = "Klebsiella_pneumoniae"

    // MLST
    mlst_scheme = "klebsiella"

    // Resources tuned for i9-14900K + 64 GB RAM (dedicated local machine)
    max_cpus   = 30
    max_memory = "60.GB"
    max_time   = "24.h"

    // Portable conda env settings (override via env vars or --params)
    conda_env_root = System.getenv('CONDA_ENVS_PATH') ?: "${System.getenv('HOME')}/miniconda3/envs"
    prokka_env        = "${params.conda_env_root}/prokka_env"
    mlst_env          = "${params.conda_env_root}/mlst_env"
    kleborate_env     = "${params.conda_env_root}/kleborate_env"
    amrfinder_env     = "${params.conda_env_root}/amrfinder_env"
    snippy_env        = "${params.conda_env_root}/snippy_env"
    iqtree_env        = "${params.conda_env_root}/iqtree_env"
}

// ============================================================
// Conda environments
// ============================================================

conda.enabled = true
conda.useMamba = true

// NOTE: Current pipeline tools are CPU-based.
// The NVIDIA RTX 5090 is not used unless GPU-enabled tools are added.

process {
    // Default
    errorStrategy = 'retry'
    maxRetries    = 1

    withName: 'PROKKA' {
        conda = "${params.prokka_env}"
        cpus   = 20
        memory = '28.GB'
    }
    withName: 'MLST' {
        conda = "${params.mlst_env}"
        cpus   = 6
        memory = '2.GB'
    }
    withName: 'KLEBORATE' {
        conda = "${params.kleborate_env}"
        cpus   = 4
        memory = '4.GB'
    }
    withName: 'AMRFINDER' {
        conda = "${params.amrfinder_env}"
        cpus   = 8
        memory = '10.GB'
    }
    withName: 'SNIPPY' {
        conda = "${params.snippy_env}"
        cpus   = 12
        memory = '16.GB'
    }
    withName: 'SNIPPY_CORE' {
        conda = "${params.snippy_env}"
        cpus   = 8
        memory = '16.GB'
    }
    withName: 'IQTREE' {
        conda = "${params.iqtree_env}"
        cpus   = 16
        memory = '28.GB'
    }
}

// ============================================================
// Execution profiles
// ============================================================

profiles {
    standard {
        process.executor = 'local'
    }
    slurm {
        process.executor = 'slurm'
        process.queue    = 'normal'
    }
}

// ============================================================
// Reports
// ============================================================

def timestamp = new java.util.Date().format('yyyyMMdd_HHmmss')

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_report_${timestamp}.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${params.outdir}/timeline_${timestamp}.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_dag_${timestamp}.html"
    overwrite = true
}

manifest {
    name        = 'kp-pipeline'
    description = 'Klebsiella pneumoniae genomic analysis pipeline'
    version     = '1.0.0'
    nextflowVersion = '>=23.0.0'
}
